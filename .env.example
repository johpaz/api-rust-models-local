# ═══════════════════════════════════════════════════════
# Configuración del Servidor LLM
# ═══════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════
# Servidor (llama-server)
# ═══════════════════════════════════════════════════════
PORT=8080
HOST=0.0.0.0

# ═══════════════════════════════════════════════════════
# Modelo
# ═══════════════════════════════════════════════════════
# Nombre del archivo del modelo en ./models/
MODEL_NAME=google_gemma-4-E4B-it-Q4_K_M.gguf

# Tamaño del contexto (tokens)
CONTEXT_SIZE=4096

# Directorio de modelos (opcional, default: ./models/)
# MODELS_DIR=/path/to/models

# ═══════════════════════════════════════════════════════
# GPU Configuration (Vulkan)
# ═══════════════════════════════════════════════════════
# Capas a offload a GPU (0 = solo CPU, 999 = todas)
GPU_LAYERS=35

# Tipo de cache KV
# Opciones: f16, q8_0, q4_0, q5_0, q5_1, turbo2, turbo3, turbo4
# Nota: turbo2/3/4 requieren --flash-attn on (se agrega automáticamente)
LLAMA_ARG_CACHE_TYPE_K=q4_0
LLAMA_ARG_CACHE_TYPE_V=q4_0

# ═══════════════════════════════════════════════════════
# Concurrencia
# ═══════════════════════════════════════════════════════
MAX_CONCURRENCY=1

# ═══════════════════════════════════════════════════════
# Vulkan GPU (no cambiar en la mayoría de casos)
# ═══════════════════════════════════════════════════════
VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/radeon_icd.x86_64.json:/usr/share/vulkan/icd.d/intel_icd.x86_64.json
MESA_VK_WSI=1

# ═══════════════════════════════════════════════════════
# API Rust (si se usa el proxy)
# ═══════════════════════════════════════════════════════
API_TOKEN=tu-token-seguro-aqui
API_PORT=9000
DEFAULT_TEMPERATURE=0.7
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_SECONDS=60
RUST_LOG=info
