# ═══════════════════════════════════════════════════════
# Configuración del Servidor API
# ═══════════════════════════════════════════════════════
PORT=3000
HOST=0.0.0.0
API_PORT=9000

# ═══════════════════════════════════════════════════════
# Configuración del Modelo
# ═══════════════════════════════════════════════════════
# Nombre del modelo GGUF dentro del contenedor
MODEL_NAME=google_gemma-4-31B-it-Q4_K_M.gguf


# Modelos disponibles en ./models/:
#   - google_gemma-4-E4B-it-Q4_K_M.gguf  (~4.5GB, 7.5B params)
#   - google_gemma-4-31B-it-Q4_K_M.gguf  (~19GB, 30.7B params)
#   - nvidia_Nemotron-Cascade-2-30B-A3B-IQ2_M.gguf (~12GB, 30B params, 3B activos)
#   - Qwen_Qwen3.5-35B-A3B-Q4_K_M.gguf   (~20GB, 35B params, 3B activos)

# Tamaño del contexto (tokens)
CONTEXT_SIZE=8192

# Temperatura por defecto
DEFAULT_TEMPERATURE=0.7

# Concurrencia máxima
MAX_CONCURRENCY=1

# ═══════════════════════════════════════════════════════
# Optimización de KV Cache (estilo TurboQuant)
# ═══════════════════════════════════════════════════════
# Tipos de cache: f16, q8_0, q4_0
# q4_0 = 4 bits (reducción 4x en memoria de KV cache)
LLAMA_ARG_CACHE_TYPE_K=q4_0
LLAMA_ARG_CACHE_TYPE_V=q4_0

# Límite de memoria para el servidor de modelos
MODEL_MEMORY_LIMIT=30G

# ═══════════════════════════════════════════════════════
# Seguridad
# ═══════════════════════════════════════════════════════
API_TOKEN=tu-token-seguro-aqui

# ═══════════════════════════════════════════════════════
# Rate Limiting
# ═══════════════════════════════════════════════════════
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_SECONDS=60

# ═══════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════
RUST_LOG=info
