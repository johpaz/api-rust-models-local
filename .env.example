# ═══════════════════════════════════════════════════════
# Configuración del servidor LLM
# ═══════════════════════════════════════════════════════

# ─── Servidor ────────────────────────────────────────
API_PORT=3001
HOST=0.0.0.0

# ─── Motor de inferencia ─────────────────────────────
# Único backend soportado: layer_streaming
INFERENCE_BACKEND=layer_streaming

# Ruta al archivo .gguf del modelo a cargar al iniciar
LAYER_STREAMING_MODEL=./models/google_gemma-4-E4B-it-Q4_K_M.gguf

# Directorio con las capas pre-divididas del modelo
# Convención: models/layers/{nombre_sin_.gguf}/
LAYER_STREAMING_LAYERS_DIR=./models/layers/google_gemma-4-E4B-it-Q4_K_M/

# ─── Modelos ─────────────────────────────────────────
# Directorio donde se buscan los archivos .gguf (default: ./models/)
# MODELS_DIR=/ruta/alternativa/models

# ─── Logging ─────────────────────────────────────────
# Niveles: error | warn | info | debug | trace
RUST_LOG=info
